    "zellij", "mc", "fuse2","glow",
,
]
"opensuse-tumbleweed" = [
    "eza", "bat", "vim", "fzf", "ripgrep", "fd", "tmux",
    "htop", "neovim", "zsh", "git", "btop", "zoxide",
    "gping", "procs", "fastfetch", "dust", "plocate",
    "zellij", "mc", "libfuse2","glow",
]
debian = [
    "bat", "vim", "fzf", "ripgrep", "fd-find", "tmux",
    "htop", "neovim", "zsh", "git", "btop", "zoxide",
    "fastfetch", "gping", "procs",
    "build-essential", "pkg-config", "libssl-dev",
    "plocate", "zellij", "mc", "libfuse2","glow",
]
ubuntu = [
    "bat", "vim", "fzf", "ripgrep", "fd-find", "tmux",
    "htop", "neovim", "zsh", "git", "btop", "zoxide",
    "fastfetch", "gping", "procs",
