    "fastfetch", "gping", "procs", "zellij", "mc", "fuse", "fuse-libs","glow",
]

[data.aur]
arch = ["lazygit-bin", "bottom-bin"]

[data.cargo]
debian  = ["eza", "du-dust"]
ubuntu  = ["eza", "du-dust"]
fedora  = ["du-dust"]

[data.symlinks]
debian = ["fdfind:fd"]
ubuntu = ["fdfind:fd"]

