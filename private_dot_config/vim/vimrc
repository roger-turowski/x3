" This must be first, because it changes other options as a side effect.
set nocompatible

" Disable backup files entirely
" set nobackup
" set nowritebackup

" Redirect swap/backup files to a temp directory
set backupdir=~/.local/state/vim/backup//
set directory=~/.local/state/vim/swap//

" Force 256 colors on the terminal
set t_Co=256

" show line numbers
set number

" Highlight cursor line underneath the cursor horizontally
set cursorline
highlight cursorline cterm=NONE ctermbg=234 ctermfg=NONE
highlight CursorLineNr cterm=NONE ctermbg=234 ctermfg=NONE " Highlight the line numbers same as the rest of the line

" Highlight the cursor column underneath the cursor vertically
set cursorcolumn
highlight CursorColumn cterm=NONE ctermbg=234 ctermfg=NONE

" display "-- INSERT --" when entering insert mode
set showmode

" incremental search
set incsearch

" highlight matching search terms
set hlsearch

" set ic means case-insensitive search; noic means case-sensitive.
set noic

" allow backspacing over any character in insert mode
set backspace=indent,eol,start

" do not wrap lines
set nowrap

" set the mouse to work in the console
set mouse=a

" keep 50 lines of command line history
set history=50

" show the cursor position
set ruler

" do incremental searching
set incsearch

" save a backup file
set backup

" the visual bell flashes the background instead of an audible bell.
set visualbell

" Turn off visual bell
set novisualbell

" set sensible defaults for different types of text files.
au FileType c set cindent tw=79
au FileType sh set ai et sw=4 sts=4 noexpandtab
au FileType vim set ai et sw=2 sts=2 noexpandtab

" indent new lines to match the current indentation
set autoindent

" don't replace tabs with spaces
set noexpandtab

" use tabs at the start of a line, spaces elsewhere
set smarttab

" show syntax highlighting
syntax on

" show whitespace at the end of a line
highlight WhitespaceEOL ctermbg=blue guibg=blue
match WhitespaceEOL /\s\+$/


" Cursor shapes
" -------------
" Reference chart of cursor values
"   Ps = 0 -> Blinking Block
"   Ps = 1 -> Blinking Block (default)
"   Ps = 2 -> Steady Block
"   Ps = 3 -> Blinking Underline
"   Ps = 4 -> Steady Underline
"   Ps = 5 -> Blinking Bar (xterm)
"   Ps = 6 -> Steady bar (xterm)
let &t_SI = "\e[3 q"
let &t_EI = "\e[2 q"

" Plug-ins
" --------
call plug#begin('~/.config/vim/plugged')

" List your plugins here
Plug 'tpope/vim-sensible'
Plug 'junegunn/fzf', { 'do': { -> fzf#install() } }
Plug 'junegunn/fzf.vim'

call plug#end()

" FZF configuration
" -----------------
" Files (respects .gitignore if fd/rg are installed)
nnoremap <leader>f :Files<CR>

" Search within open buffers
nnoremap <leader>b :Buffers<CR>

" Grep project-wide (uses rg if available, falls back to grep)
nnoremap <leader>g :Rg<CR>

" Recently opened files
nnoremap <leader>r :History<CR>

" Git commits
nnoremap <leader>c :Commits<CR>

" Lines in current buffer
nnoremap <leader>l :BLines<CR>

" Marks
nnoremap <leader>m :Marks<CR>

" Open fzf in a centered floating-ish split (works well in terminal Vim)
let g:fzf_layout = { 'down': '40%' }

" Preview window for :Files and :Rg
let g:fzf_preview_window = ['right:50%', 'ctrl-/']

" Better Rg behavior — don't start searching until you type something
command! -bang -nargs=* Rg
  \ call fzf#vim#grep(
  \   'rg --column --line-number --no-heading --color=always --smart-case '.shellescape(<q-args>),
  \   1,
  \   fzf#vim#with_preview(),
  \   <bang>0)

" Customize colors to match your theme
let g:fzf_colors = {
  \ 'fg':      ['fg', 'Normal'],
  \ 'bg':      ['bg', 'Normal'],
  \ 'hl':      ['fg', 'Comment'],
  \ 'fg+':     ['fg', 'CursorLine', 'CursorColumn', 'Normal'],
  \ 'bg+':     ['bg', 'CursorLine', 'CursorColumn'],
  \ 'hl+':     ['fg', 'Statement'],
  \ 'info':    ['fg', 'PreProc'],
  \ 'border':  ['fg', 'Ignore'],
  \ 'prompt':  ['fg', 'Conditional'],
  \ 'pointer': ['fg', 'Exception'],
  \ 'marker':  ['fg', 'Keyword'],
  \ 'spinner': ['fg', 'Label'],
  \ 'header':  ['fg', 'Comment']
  \ }

