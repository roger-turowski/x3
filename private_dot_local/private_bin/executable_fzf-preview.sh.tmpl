#!/usr/bin/env bash

# fzf-preview.sh
# Based on "private_dot_local/private_bin//executable_fzf-preview.sh.tmpl"

# Handles formatting in the fzf preview to use glow to render markdown files,
# a quick hex dump of binary files and bat to preview the rest.


export TERM=xterm-256color
export COLORTERM=truecolor
export CLICOLOR_FORCE=1

file_path="$1"

# Route by extension for markdown
ext="${file_path##*.}"
ext_lower=$(echo "$ext" | tr '[:upper:]' '[:lower:]')

max_size=$(({{ .fzf_preview_max_size | default "256" }} * 1024))  # 10KB preview cap
file_size=$(stat -f%z "$file_path" 2>/dev/null || stat -c%s "$file_path" 2>/dev/null)
if [[ $file_size -gt $max_size ]]; then
    echo -e "\033[1;36mFile too large for preview ($((file_size / 1024)) KB)\033[0m"
    exit 0
fi

case "$ext_lower" in
    appimage)
        readelf -h "$file_path"
	;;
    md|markdown|mkd|mdown|markdn)
        glow -s {{ .fzf_preview_glow_style | default "dark" }} "$file_path"
	# Use bat if you want unrendered output.
	# bat --language=markdown --color=always "$file_path" 2>/dev/null || cat "$file_path"
        ;;
    jpg|jpeg|png)
        exiftool -S "$file_path"
	;;
    lock)
	exit 0
        ;;
    bzip2|bz2)
        bzcat "$file_path"
	;;
    gz|gzip)
        zcat -l "$file_path" && printf "\n"
	;;
    xz)
        xz -l "file_path" && printf "\n"
	;;
    zip)
        unzip -l "$file_path" && printf "\n"
        unzip -p "$file_path"
        ;;
    *)
        # Detect ibinary file type
        if file --mime-encoding "$file_path" | grep -q "binary"; then
            # Get file size for a useful message
            size=$(du -h "$file_path" | cut -f1)
            echo -e "\033[1;33mBinary file\033[0m"
            echo -e "Size: ${size}"
            echo ""
            # Show hex dump of the first few bytes for quick inspection
            xxd "$file_path" | head -5
            exit 0
        fi
        # Use default tool to view
        bat --style=default --color=always "$file_path" 2>/dev/null || cat "$file_path"
        ;;

esac
